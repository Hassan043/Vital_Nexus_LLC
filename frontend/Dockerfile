# Build context: frontend/
# Example: docker build -f Dockerfile -t vitalnexus-frontend:local .

FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

ARG VITE_B2C_CLIENT_ID
ARG VITE_B2C_TENANT_ID
ARG VITE_B2C_TENANT_KIND=ciam
ARG VITE_B2C_TENANT_DOMAIN_PREFIX
ARG VITE_B2C_USER_FLOW
ARG VITE_B2C_API_SCOPE
ARG VITE_B2C_REDIRECT_URI

ENV VITE_B2C_CLIENT_ID=$VITE_B2C_CLIENT_ID
ENV VITE_B2C_TENANT_ID=$VITE_B2C_TENANT_ID
ENV VITE_B2C_TENANT_KIND=$VITE_B2C_TENANT_KIND
ENV VITE_B2C_TENANT_DOMAIN_PREFIX=$VITE_B2C_TENANT_DOMAIN_PREFIX
ENV VITE_B2C_USER_FLOW=$VITE_B2C_USER_FLOW
ENV VITE_B2C_API_SCOPE=$VITE_B2C_API_SCOPE
ENV VITE_B2C_REDIRECT_URI=$VITE_B2C_REDIRECT_URI

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS final
WORKDIR /usr/share/nginx/html

COPY --from=build /app/dist ./
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
