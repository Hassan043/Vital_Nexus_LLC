# Entra External ID (MSAL) — local development
# Copy to .env.development.local and fill in values from your dev external tenant.

# VitalNexus Frontend Dev application (client) ID
VITE_B2C_CLIENT_ID=

# External tenant GUID
VITE_B2C_TENANT_ID=

# CIAM dev tenant domain prefix (without .onmicrosoft.com)
VITE_B2C_TENANT_DOMAIN_PREFIX=vitalnexusexternal

# ciam | b2c — dev uses ciam
VITE_B2C_TENANT_KIND=ciam

# Legacy B2C only (test/prod)
# VITE_B2C_USER_FLOW=B2C_1_VitalNexusSignUpSignIn

# Delegated API scope for access tokens after sign-in (not used on login redirect)
VITE_B2C_API_SCOPE=https://vitalnexusexternal.onmicrosoft.com/vitalnexus-api/access_as_user

# Must match SPA redirect URI registration exactly
VITE_B2C_REDIRECT_URI=http://localhost:5173/

# VitalNexus API base URL (local API launch profile)
VITE_API_BASE_URL=http://localhost:5158
